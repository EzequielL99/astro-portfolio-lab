---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
}

const { href, variant = "primary" } = Astro.props;
---

<a
  href={href}
  class:list={[
    "inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-cyan-300 focus:ring-offset-2 focus:ring-offset-slate-950",
    {
      "bg-teal-400 text-slate-950! hover:bg-teal-200": variant === "primary",
      "border border-slate-700 bg-slate-900/70 text-slate-100! hover:border-cyan-300/60 hover:text-cyan-300!":
        variant === "secondary",
    },
  ]}
>
  <slot />
</a>

---
interface Props {
  title: string;
  description: string;
  type: "frontend" | "fullstack" | "rpa" | "landing";
  status: "planned" | "in-progress" | "completed";
  stack: string[];
  href: string;
  featured?: boolean;
}

const {
  title,
  description,
  type,
  status,
  stack,
  href,
  featured = false,
} = Astro.props;
---

<article
  class:list={[
    "rounded-2xl border border-white/10 bg-white/5 p-6 transition hover:border-cyan-400/30 hover:bg-white/[0.07] ",
  ]}
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-sm text-(--color-primary)">{type}</p>
      <p class="mt-1 text-xs text-slate-400">
        Estado: {status}
      </p>
    </div>

    {
      featured && (
        <span class="rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-sm font-medium text-(--color-primary)">
          Destacado
        </span>
      )
    }
  </div>

  <h2 class="mt-4 text-xl font-semibold">
    <a href={href} class="transition hover:text-(--color-primary)">
      {title}
    </a>
  </h2>

  <p class="mt-3 text-sm leading-6 text-slate-300">
    {description}
  </p>

  <ul class="mt-4 flex flex-wrap gap-2">
    {
      stack.map((item) => (
        <li class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-200">
          {item}
        </li>
      ))
    }
  </ul>
</article>

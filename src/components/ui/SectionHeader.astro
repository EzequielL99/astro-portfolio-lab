---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;

const alignmentClasses = {
  left: "items-start text-left",
  center: "items-center text-center mx-auto",
} as const;
---

<header class:list={["flex max-w-3xl flex-col gap-3", alignmentClasses[align]]}>
  {
    eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-teal-300">
        {eyebrow}
      </p>
    )
  }

  <h2 class="text-3xl font-bold tracking-tight text-slate-50 sm:text-4xl">
    {title}
  </h2>

  {
    description && (
      <p class="text-base leading-7 text-slate-400 sm:text-lg">{description}</p>
    )
  }
</header>

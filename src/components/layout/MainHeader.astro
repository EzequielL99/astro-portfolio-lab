---
import Container from "../ui/Container.astro";

const navItems = [
  { label: "Frontend", href: "/frontend" },
  { label: "RPA", href: "/rpa" },
  { label: "Landing", href: "/landing" },
  { label: "Contacto", href: "/contact" },
] as const;
---

<header class="border-b border-slate-800/80 bg-slate-950/60 backdrop-blur">
  <Container class="flex h-16 items-center justify-between">
    <a href="/" class="text-sm font-bold tracking-wide text-slate-100">
      Astro Portfolio Lab
    </a>

    <nav
      class="hidden items-center gap-6 md:flex"
      aria-label="Navegacion principal"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-slate-300 transition hover:text-cyan-200"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </Container>
</header>

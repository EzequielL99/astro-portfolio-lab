---
import { Icon } from "astro-icon/components";

const socialMediaItems = [
  { icon: "social-media/linkedin", href: "/" },
  { icon: "social-media/github", href: "https://github.com/EzequielL99" },
] as const;
---

<nav class="hidden items-center gap-3 md:flex" aria-label="Redes sociales">
  {
    socialMediaItems.map((item) => (
      <a href={item.href} class="text-slate-300 transition hover:text-cyan-300">
        <Icon name={item.icon} class="w-6 h-6" />
      </a>
    ))
  }
</nav>

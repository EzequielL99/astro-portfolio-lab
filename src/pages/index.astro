---
import Badge from "../components/ui/Badge.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import Container from "../components/ui/Container.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const technologies = [
  "Astro",
  "TypeScript",
  "Tailwind CSS",
  "React",
  "SEO",
  "Netlify",
] as const;
---

<BaseLayout
  title="Astro Portfolio Lab | Curso practico"
  description="Proyecto practico para aprender Astro con TypeScript estricto, Tailwind CSS, SEO y despliegue en Netlify."
>
  <section class="py-24 sm:py-32">
    <Container>
      <div class="max-w-3xl">
        <Badge label="Curso practico de Astro" />

        <h1
          class="mt-6 text-4xl font-bold tracking-tight text-slate-50 sm:text-6xl"
        >
          Construccion de portfolios y landing pages con Astro
        </h1>

        <p class="mt-6 text-lg leading-8 text-slate-300">
          Este proyecto sera la base para desarrollar un portfolio frontend, un
          portfolio RPA con blog tecnico y una landing page profesional
          optimizada para SEO.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <ButtonLink href="/frontend">Ver portfolio frontend</ButtonLink>
          <ButtonLink href="/rpa" variant="secondary"
            >Ver portfolio RPA</ButtonLink
          >
        </div>

        <ul
          class="mt-10 flex flex-wrap gap-3"
          aria-label="Tecnologias principales"
        >
          {
            technologies.map((tech) => (
              <li>
                <span class="rounded-lg border border-slate-700 bg-slate-900/70 px-3 py-2 text-sm text-slate-300">
                  {tech}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </section>
</BaseLayout>

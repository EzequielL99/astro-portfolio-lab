---
import Badge from "../components/ui/Badge.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import Container from "../components/ui/Container.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const technologies = [
  "Blue Prism",
  "Astro",
  "Power Automate",
  "TypeScript",
  "Tailwind CSS",
  "React",
  "SEO",
  "JavaScript",
] as const;
---

<BaseLayout
  title="Astro Portfolio Lab | Curso practico"
  description="Proyecto practico para aprender Astro con TypeScript estricto, Tailwind CSS, SEO y despliegue en Netlify."
>
  <section class="py-24 sm:py-32">
    <Container>
      <div class="max-w-3xl">
        <Badge label="Desarrollo Web - RPA" />

        <h1
          class="mt-6 text-4xl font-bold tracking-tight text-slate-50 sm:text-6xl"
        >
          Potenciando tu capacidad de <span class="text-teal-400"
            >automatización</span
          > y <span class="text-teal-400">posicionamiento</span> en internet.
        </h1>

        <p class="mt-6 text-lg leading-8 text-slate-300">
          Hola, mi nombre es <strong class="text-teal-400"
            >Ezequiel Lopez</strong
          >, es un gusto y un honor para mi que le eches un vistazo a mi perfil.
          Te invito a revisar el portfolio que mejor se adapte a lo que buscas. <strong
            >Gracias!</strong
          >
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <ButtonLink href="/rpa"> Ver portfolio RPA </ButtonLink>
          <ButtonLink href="/frontend" variant="secondary"
            >Ver portfolio frontend</ButtonLink
          >
        </div>

        <ul
          class="mt-10 flex flex-wrap gap-3"
          aria-label="Tecnologias principales"
        >
          {
            technologies.map((tech) => (
              <li>
                <span class="rounded-lg border border-slate-700 bg-slate-900/70 px-3 py-2 text-sm text-slate-300">
                  {tech}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </section>
</BaseLayout>

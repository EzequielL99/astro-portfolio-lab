---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
---

<BaseLayout
  title="Portfolio Frontend | Astro Portfolio Lab"
  description="Portfolio frontend desarrollado con Astro, TypeScript y Tailwind CSS."
>
  <section class="py-24">
    <Container>
      <h1 class="text-4xl font-bold text-slate-50">Portfolio Frontend</h1>
      <p class="mt-4 max-w-2xl text-slate-300">
        Aca construiremos el portfolio orientado a desarrollo frontend.
      </p>
    </Container>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
---

<BaseLayout
  title="Portfolio Frontend | Astro, React y TypeScript"
  description="Portfolio orientado a desarrollo frontend con foco en Astro, React, TypeScript, Tailwind CSS, performance y buenas prácticas."
>
  <section class="py-24">
    <Container>
      <h1
        class="text-4xl font-semibold tracking-tight text-slate-50 sm:text-5xl"
      >
        Portfolio Frontend
      </h1>
      <p class="mt-6 max-w-2xl text-base text-(--color-muted) sm:text-lg">
        Proyectos, enfoque técnico y experiencia orientados a construir
        interfaces modernas, rápidas, accesibles y mantenibles.
      </p>
    </Container>
  </section>
</BaseLayout>
